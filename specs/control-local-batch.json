{
  "environments": [
    {
      "env": "Hopper-v5",
      "env_kwargs": {"max_episode_steps": 1000},
      "delay": 3,
      "num_steps": 1e5,
      "eval_step_freq": 400,
      "sac_kwargs": {
        "learning_rate": 3e-4,
        "buffer_size": 1000000,
        "batch_size": 128,
        "gradient_steps": -1,
        "verbose": 1
      },
      "experiments": [
        {
          "reward_model_type": "none"
        },
        {
          "reward_model_type": "ircr",
          "reward_model_kwargs": {"max_buffer_size": 10000, "k_neighbors": 5}
        },
        {
          "reward_model_type": "dgra",
          "reward_model_kwargs": {
            "max_buffer_size": 20000,
            "train_epochs": 50,
            "batch_size": 64,
            "regu_lam": 1.0,
            "learning_rate": 1e-3,
            "train_epochs_decay": 0.99
          }
        },
        {
          "reward_model_type": "grd",
          "reward_model_kwargs": {
            "max_buffer_size": 300,
            "train_epochs": 50,
            "batch_size": 4,
            "trans_batch_size": 256,
            "dyn_weight": 1.0,
            "sparsity_lam_diag": 1e-4,
            "sparsity_lam_offdiag": 1e-5,
            "learning_rate": 3e-4,
            "train_epochs_decay": 0.99
          }
        },        
        {
          "agent_type": "hc",
          "agent_kwargs": {"history_hidden_size": 48, "projection_dim": 48, "reg_lambda": 5.0}
        }
      ]
    }
  ]
}
